{
  "name": "spit-the-diff",
  "version": "1.0.0",
  "description": "Where your diffs drop bars. A GitHub Action that generates creative PR summaries using AI.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --noEmit && ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:yaml": "yamllint action.yml .github/workflows/ci.yml .github/workflows/spit-the-diff.yml examples/workflow.yml",
    "lint:all": "npm run lint && npm run lint:md && npm run lint:yaml"
  },
  "keywords": [
    "github-action",
    "pull-request",
    "ai",
    "rap",
    "openai",
    "code-review",
    "developer-tools"
  ],
  "author": "ssfinney",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "openai": "^4.52.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "markdownlint-cli": "^0.48.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18",
    "yaml-lint": "^1.7.0"
  }
}
